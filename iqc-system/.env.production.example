# ============================================================================
# IQC System — production environment (คัดลอกเป็น .env.production แล้วแก้ค่า)
#   cp .env.production.example .env.production
# ห้าม commit .env.production เข้า git
# ============================================================================

NODE_ENV=production
PORT=3001
TZ=Asia/Bangkok

# JWT secret — บังคับ >= 32 ตัว (แนะนำ 64) ไม่งั้น server จะไม่ start ใน production
#   สร้าง: openssl rand -hex 48
JWT_SECRET=

# bcrypt cost (12 = มาตรฐาน)
BCRYPT_ROUNDS=12

# เข้ารหัส secret ใน settings table (เช่น ad_secret_key) — hex 64 ตัวอักษร (32 bytes)
#   สร้าง: openssl rand -hex 32
# ต้องตั้งก่อนบันทึกค่า Active Directory ผ่านหน้า Admin > ตั้งค่าระบบ (ไม่ตั้งก็ boot ได้ปกติ — AD เป็น feature เสริม)
SETTINGS_ENCRYPTION_KEY=

# URL สาธารณะของระบบ — ใช้กับ CORS origin + ตรวจ cookie. ใส่ origin จริง (https)
APP_URL=https://your-domain.com

# secure cookie: ปล่อยว่าง = อัตโนมัติ (production = true ต้องใช้ https)
#   ตั้ง false เฉพาะตอนทดสอบ local ผ่าน http://localhost เท่านั้น — production ห้ามตั้ง false
# COOKIE_SECURE=false

# ----- Persistence (ตั้งไว้แล้วใน Dockerfile/compose; ใส่ซ้ำเพื่อความชัดเจน) -----
# SQLite ต้องอยู่บน volume เท่านั้น (ห้าม ephemeral) — ยกเว้น deployment ที่ตั้งใจใช้ RESTORE_ON_BOOT
# แทน persistent disk (เช่น Render free tier — ดู DEPLOYMENT.md หัวข้อ "Render Free tier")
IQC_DB_PATH=/data/iqc.db
# Chromium ของระบบ (ติดตั้งผ่าน apt ใน image)
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# หมายเหตุ: ค่า Telegram bot/กลุ่ม ตั้งในระบบที่หน้า Admin > Settings (เก็บใน DB) ไม่ใช่ env

# ----- Cloudflare R2 backup (optional) — ตั้งค่าเพื่อเปิด backup-to-cloud (server/lib/r2Client.js) -----
# ไม่ตั้งก็ boot ได้ปกติ (ฟีเจอร์เสริม เหมือน SETTINGS_ENCRYPTION_KEY) — แค่จะไม่มี backup ขึ้น R2
# สร้าง R2 bucket + API token (Object Read & Write) จาก Cloudflare Dashboard > R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ----- Restore-on-boot (เฉพาะ Render free tier / deployment ที่ไม่มี persistent disk) -----
# true = ตอน boot ถ้า DB local ที่ IQC_DB_PATH ไม่มี/ว่างเปล่า จะดาวน์โหลด backup ล่าสุดจาก R2 มาก่อน
# (ดู server/bootstrap.js / server/lib/restoreService.js) — deployment ที่มี persistent volume (VPS/docker-compose
# ปกติ) ไม่ต้องตั้งค่านี้ (ปล่อยว่าง/false ก็พอ เพราะมี DB local อยู่แล้วเสมอ ฟังก์ชันจะ no-op เอง)
RESTORE_ON_BOOT=false

# ----- Telegram alert ตอน boot (optional) — ใช้เฉพาะตอน restore-on-boot ล้มเหลว -----
# ต้องเป็น env var แยกจาก Telegram settings ปกติใน DB เพราะตอนนี้ยังไม่มี DB connection ที่เชื่อถือได้
# (ใช้ bot token/chat id เดียวกับที่ตั้งในหน้า Admin > Settings ก็ได้ — คัดลอกมาใส่ตรงนี้อีกชุด)
TELEGRAM_BOOT_ALERT_TOKEN=
TELEGRAM_BOOT_ALERT_CHAT_ID=
